rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users Profile Collection Rules
    match /Users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Swap Requests Collection Rules
    match /swapRequests/{requestId} {
      // Authenticated users can send a swap request where they are the sender
      allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      
      // Only the sender or receiver can view or update the status of a request
      allow read, update, delete: if request.auth != null && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
    }

    // Learning Rooms Collection Rules
    match /learningRooms/{roomId} {
      // Only participants belonging to the room's participant list can access or write to it
      allow read, update, delete: if request.auth != null && (
        request.auth.uid in resource.data.participants
      );
      
      // Allow creation of a room if the current user is listed as a participant
      allow create: if request.auth != null && (
        request.auth.uid in request.resource.data.participants
      );

      // Subcollections under learningRooms
      match /notes/{noteId} {
        allow read, write: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/learningRooms/$(roomId)).data.participants
        );
      }

      match /resources/{resourceId} {
        allow read, create: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/learningRooms/$(roomId)).data.participants
        );
        allow delete: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/learningRooms/$(roomId)).data.participants
        ) && resource.data.uploadedBy == request.auth.uid;
      }

      match /tasks/{taskId} {
        allow read, write: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/learningRooms/$(roomId)).data.participants
        );
      }

      match /activities/{activityId} {
        allow read, create: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/learningRooms/$(roomId)).data.participants
        );
        allow update, delete: if false;
      }

      match /meetings/{meetingId} {
        allow read, write: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/learningRooms/$(roomId)).data.participants
        );
      }

      match /studyPlans/{planId} {
        allow read, write: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/learningRooms/$(roomId)).data.participants
        );
      }

      match /sessionSummaries/{summaryId} {
        allow read, write: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/learningRooms/$(roomId)).data.participants
        );
      }
    }

    // Notifications Collection Rules
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null; // Allowing users to trigger alerts for others
    }

    // Marketplace Collection Rules
    match /marketplacePosts/{postId} {
      allow read: if true; // Feed is public or authenticated depending on requirement (true for now)
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }

    // Verification Collection Rules
    match /verificationRequests/{requestId} {
      // Allow read/update if user owns the request or if user is an admin (mocked via claim or open for MVP)
      allow read: if request.auth != null; // Opened up for admin dashboard
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null; 
    }

    match /certificateSubmissions/{subId} {
      allow read, create, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
