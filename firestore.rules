rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users Profile Collection Rules
    match /Users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Swap Requests Collection Rules
    match /swapRequests/{requestId} {
      // Authenticated users can send a swap request where they are the sender
      allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      
      // Only the sender or receiver can view or update the status of a request
      allow read, update, delete: if request.auth != null && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
    }

    // Learning Rooms Collection Rules
    match /learningRooms/{roomId} {
      // Only participants belonging to the room's participant list can access or write to it
      allow read, update, delete: if request.auth != null && (
        request.auth.uid in resource.data.participants
      );
      
      // Allow creation of a room if the current user is listed as a participant
      allow create: if request.auth != null && (
        request.auth.uid in request.resource.data.participants
      );
    }
  }
}
